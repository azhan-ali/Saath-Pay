# ─── Dependencies ───────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js build output ───────────────────────────────────
/.next/
/out/
/build

# ─── Environment files (NEVER commit real keys) ─────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
# .env.example is SAFE to commit — it has no real values
# so we explicitly allow it:
!.env.example

# ─── Solana / Anchor keypairs (NEVER commit) ────────────────
*.json.bak
id.json
deploy-keypair.json
wallet.json
/target/deploy/*.json

# ─── OS / Editor ────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.vscode/settings.json
.idea/

# ─── Debug logs ─────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── TypeScript ─────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Vercel ─────────────────────────────────────────────────
.vercel

# ─── Testing ────────────────────────────────────────────────
/coverage

# ─── Misc ───────────────────────────────────────────────────
*.log
.cache/
