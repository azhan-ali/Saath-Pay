# ──────────────────────────────────────────────────────────────
# SaathPay — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit .env.local — it's in .gitignore.
# ──────────────────────────────────────────────────────────────

# ── Supabase ── (get from app.supabase.com → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key

# ── Solana ── (devnet for hackathon, mainnet-beta for production)
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_ESCROW_PROGRAM_ID=
NEXT_PUBLIC_USDC_MINT=

# ── Stripe (payment provider — available in India) ──
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get from: stripe listen --forward-to localhost:3000/api/webhooks/dodo
# OR Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Dodo Payments (optional — use when available in your region) ──
# DODO_API_KEY=
# DODO_WEBHOOK_SECRET=
# NEXT_PUBLIC_DODO_PUBLIC_KEY=

# ── Google Gemini AI ── (get free key from aistudio.google.com/apikey)
GEMINI_API_KEY=AIzaSy...

# ── App URL ── (change to your Vercel URL in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
